{
  "name": "llm-project-harness",
  "private": true,
  "version": "0.0.0",
  "description": "Reusable cross-agent LLM project harness for product repositories.",
  "type": "module",
  "scripts": {
    "build": "node scripts/harness/check-node-syntax.mjs",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "harness:start": "node scripts/harness/raw-start.mjs",
    "harness:ingest": "node scripts/harness/wiki-ingest.mjs",
    "harness:check": "node scripts/harness/artifact-check.mjs",
    "harness:gate": "node scripts/harness/gate.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "vitest": "^4.1.8"
  }
}
